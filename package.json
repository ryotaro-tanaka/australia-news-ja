{
  "name": "news",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev -- vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "post:threads": "tsx scripts/post-threads.ts",
    "post:latest": "tsx scripts/post-latest-news.ts",
    "pr:check": "npm run lint && npm run build",
    "deploy": "npm run build && wrangler pages deploy dist",
    "preview": "npm run build && wrangler pages dev dist"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.83.0"
  }
}
